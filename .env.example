# .env.example — template for required environment variables.
#
# Copy to .env (which is git-ignored) and fill in real values.
# For production, use a secret manager (Doppler, AWS Secrets Manager, Vault, 1Password).
# NEVER commit real secrets. Pre-commit's `gitleaks` hook scans for them.
#
# Convention: one variable per line, grouped by category, with an inline comment
# explaining what the value is used for. Keep secrets here as placeholders only.

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
NODE_ENV=development             # or production | test | staging
LOG_LEVEL=info                   # debug | info | warn | error
APP_HOST=localhost
APP_PORT=8080

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@localhost:5432/dbname
# DATABASE_POOL_MAX=20
# DATABASE_SSL=disable           # disable | require | verify-ca | verify-full

# ----------------------------------------------------------------------------
# Cache / queue (enable what you use)
# ----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379/0
# QUEUE_URL=amqp://localhost:5672

# ----------------------------------------------------------------------------
# Auth
# ----------------------------------------------------------------------------
# JWT_SECRET=replace-me-with-a-long-random-string
# JWT_ISSUER=example-project
# JWT_AUDIENCE=example-project
# SESSION_COOKIE_NAME=session
# SESSION_COOKIE_SECURE=true     # set to false only in local dev

# ----------------------------------------------------------------------------
# AI / LLM providers (enable what you use)
# ----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# MODEL_DEFAULT=claude-sonnet-4-5
# MAX_TOKENS=4096

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# SENTRY_DSN=
# METRICS_PORT=9090

# ----------------------------------------------------------------------------
# Third-party integrations (enable what you use)
# ----------------------------------------------------------------------------
# GITHUB_TOKEN=
# SLACK_WEBHOOK_URL=
# STRIPE_API_KEY=

# ----------------------------------------------------------------------------
# Feature flags (keep short-lived; remove once promoted)
# ----------------------------------------------------------------------------
# FEATURE_NEW_CHECKOUT=false
